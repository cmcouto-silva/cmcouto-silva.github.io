@article{jacovas2018,
abstract = {The Andean Altiplano has been occupied continuously since the late Pleistocene, ~12,000 years ago, which places the Andean natives as one of the most ancient populations living at high altitudes. In the present study, we analyzed genomic data from Native Americans living a long-time at Andean high altitude and at Amazonia and Mesoamerica lowland areas. We have identified three new candidate genes - SP100, DUOX2 and CLC - with evidence of positive selection for altitude adaptation in Andeans. These genes are involved in the TP53 pathway and are related to physiological routes important for high-altitude hypoxia response, such as those linked to increased angiogenesis, skeletal muscle adaptations, and immune functions at the fetus-maternal interface. Our results, combined with other studies, showed that Andeans have adapted to the Altiplano in different ways and using distinct molecular strategies as compared to those of other natives living at high altitudes.},
author = {Jacovas, Vanessa C. and Couto-Silva, Cainã M. and Nunes, Kelly and Lemes, Renan B. and de Oliveira, Marcelo Z. and Salzano, Francisco M. and Bortolini, Maria Cátira and Hünemeier, Tábita},
doi = {10.1038/s41598-018-31100-6},
issn = {2045-2322},
journal = {Scientific Reports},
keywords = {Adaptation, Physiological, Alleles, Altitude, American Native Continental Ancestry Group, Genetic Loci, Genetics, Population, Geography, Haplotypes, Homozygote, Humans, Polymorphism, Single Nucleotide, Selection, Genetic, South America},
language = {eng},
number = {1},
pages = {12733},
pmcid = {PMC6109162},
pmid = {30143708},
title = {Selection scan reveals three new loci related to high altitude adaptation in Native Andeans},
volume = {8},
year = {2018}
}

